# Copy to .env for the app to read (it is gitignored). The app loads only this
# project-local .env, never ~/.env. In dev and production the defaults below are
# fine — there is no database to configure.

# Directory holding the slot files. Defaults to ./data beside the code (denied
# to the web by .htaccess). Set this only to relocate storage off the web root.
# BDDPHP_DATA_DIR=/home/user/bdd-data

# Default entry lifetime (seconds), snapped to a bucket: 300/3600/86400/604800.
# BDDPHP_DEFAULT_TTL=86400
