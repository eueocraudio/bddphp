# Copy to .env for the app to read (it is gitignored). The app loads only this
# project-local .env, never ~/.env. In production the deploy script generates
# this file from the ~/.env "BDD PHP" section and uploads it beside the code.

# Either set a full DSN...
# BDDPHP_DSN=mysql:host=127.0.0.1;dbname=bddphp;charset=utf8mb4
# BDDPHP_DB_USER=bddphp
# BDDPHP_DB_PASS=secret

# ...or the per-piece "_BDD" scheme (shared with ~/.env and deploy.sh):
MYSQL_HOST_BDD=127.0.0.1
MYSQL_DATA_BDD=bddphp
MYSQL_USER_BDD=bddphp
MYSQL_PASS_BDD=bddphp
BDDPHP_DB_CHARSET=utf8mb4

# Default entry lifetime (seconds), snapped to a bucket: 300/3600/86400/604800.
# BDDPHP_DEFAULT_TTL=86400
